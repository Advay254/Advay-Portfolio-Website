# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL / Supabase connection string
# Get from: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Admin Panel ────────────────────────────────────────────────────────────────
# Secret URL path for the admin dashboard — make this hard to guess
# Example: xk9m4a-panel → your admin is at https://yoursite.onrender.com/xk9m4a-panel
ADMIN_PATH=your-secret-admin-path

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ── Security ───────────────────────────────────────────────────────────────────
# Long random string for JWT signing — generate at: https://randomkeygen.com
JWT_SECRET=your-very-long-random-jwt-secret-here

# ── AI Chat ────────────────────────────────────────────────────────────────────
# Groq API key — get one free at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# ── Site ───────────────────────────────────────────────────────────────────────
# Display name shown in the browser tab
SITE_NAME=AdvaySocialSuite

# Set automatically by Render — do not set manually
# PORT=3000
